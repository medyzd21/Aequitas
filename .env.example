AEQUITAS_DEVTOOLS=1
ANVIL_RPC_URL=http://127.0.0.1:8545

# Local Anvil private key used only for the local demo stack.
# Use one of Anvil's deterministic dev keys, never a real funded key.
ANVIL_PK=replace_with_local_anvil_private_key

# Optional Sepolia deploy/import support. Not required for local jury demos.
SEPOLIA_RPC_URL=
DEPLOYER_PK=
ETHERSCAN_API_KEY=
