uts\":[{\"internalType\":\"bytes32\",\"name\":\"role\",\"type\":\"bytes32\"},{\"internalType\":\"address\",\"name\":\"account\",\"type\":\"address\"}],\"name\":\"revokeRole\",\"outputs\":[],\"stateMutability\":\"nonpayable\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"uint256\",\"name\":\"shares_\",\"type\":\"uint256\"}],\"name\":\"shareToAssets\",\"outputs\":[{\"internalType\":\"uint256\",\"name\":\"\",\"type\":\"uint256\"}],\"stateMutability\":\"view\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"address\",\"name\":\"wallet\",\"type\":\"address\"}],\"name\":\"sharesOf\",\"outputs\":[{\"internalType\":\"uint256\",\"name\":\"\",\"type\":\"uint256\"}],\"stateMutability\":\"view\",\"type\":\"function\"},{\"inputs\":[],\"name\":\"simulateYield\",\"outputs\":[],\"stateMutability\":\"payable\",\"type\":\"function\"},{\"inputs\":[],\"name\":\"totalAssets\",\"outputs\":[{\"internalType\":\"uint256\",\"name\":\"\",\"type\":\"uint256\"}],\"stateMutability\":\"view\",\"type\":\"function\"},{\"inputs\":[],\"name\":\"totalShares\",\"outputs\":[{\"internalType\":\"uint256\",\"name\":\"\",\"type\":\"uint256\"}],\"stateMutability\":\"view\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"address\",\"name\":\"newOwner\",\"type\":\"address\"}],\"name\":\"transferOwnership\",\"outputs\":[],\"stateMutability\":\"nonpayable\",\"type\":\"function\"},{\"stateMutability\":\"payable\",\"type\":\"receive\"}],\"devdoc\":{\"kind\":\"dev\",\"methods\":{\"deposit(address,uint256)\":{\"details\":\"`wallet` is the member on whose behalf shares are minted; caller      must have DEPOSIT_ROLE (typically CohortLedger-linked treasury      or the member via a wrapper). `msg.value` is the asset amount.\"},\"releaseMortalityCredit(address)\":{\"details\":\"Anyone can trigger the credit once the oracle has confirmed the      death \\u2014 the action is deterministic and verifiable.\"},\"simulateYield()\":{\"details\":\"MVP yield source: admin/strategy tops up the pool with assets.      Real integration later: IERC4626 strategy or Chainlink data-feed      based yield accrual.\"}},\"title\":\"LongevaPool \\u2014 tontine-style longevity pool (Longeva).\",\"version\":1},\"userdoc\":{\"kind\":\"user\",\"methods\":{\"payTo(address,uint256)\":{\"notice\":\"Pays `amount` of accounting asset to `to`. Caller must be a         whitelisted payout module (VestaRouter / BackstopVault).\"}},\"notice\":\"Simple share-based pool denominated in the chain's native asset         (ETH for the MVP \\u2014 swap to a stablecoin later). Works like a         minimal ERC-4626 vault:             sharesMinted = amount * totalShares / totalAssets                            (if totalShares == 0: sharesMinted = amount)             shareToAssets(s) = s * totalAssets / totalShares         Three ways assets / shares change:           1. `deposit`              \\u2014 member adds assets, gets shares.           2. `simulateYield`        \\u2014 admin tops up assets (raises NAV).           3. `releaseMortalityCredit` \\u2014 oracle confirms death; deceased's              shares are burned, assets STAY in the pool (NAV/share up).              This is the core longevity-credit mechanism.           4. `payTo`                \\u2014 whitelisted router/backstop pulls              assets out to fund retirement payments.         The off-chain Python engine computes actuarial reserves; this         contract only executes share math and honours oracle deaths.\",\"version\":1}},\"settings\":{\"compilationTarget\":{\"src/LongevaPool.sol\":\"LongevaPool\"},\"evmVersion\":\"paris\",\"libraries\":{},\"metadata\":{\"bytecodeHash\":\"ipfs\"},\"optimizer\":{\"enabled\":true,\"runs\":200},\"remappings\":[\":forge-std/=lib/forge-std/src/\"],\"viaIR\":true},\"sources\":{\"src/LongevaPool.sol\":{\"keccak256\":\"0x0efe2315695936811165e7a99c50a26443c0b7f90b2278bbe20a80166eccebb7\",\"license\":\"MIT\",\"urls\":[\"bzz-raw://b843f6155ab2a6ff055827cf78ee76a3f0512aab51d17a09fccc77aa4fcacc76\",\"dweb: