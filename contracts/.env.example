# Copy to .env and fill. NEVER commit a real private key.
#
# Required for Sepolia deployments:
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_KEY
PRIVATE_KEY=0xYOURPRIVATEKEYHEX

# Optional role-holder overrides for Deploy.s.sol. If unset, the
# broadcasting EOA (msg.sender) receives all the roles — fine for a
# local anvil demo, but you'll want distinct addresses on Sepolia.
#
# DEPLOY_REPORTER=0x...   # pushes stress updates to StressOracle
# DEPLOY_GUARDIAN=0x...   # releases reserves from BackstopVault
# DEPLOY_OPERATOR=0x...   # opens retirements via VestaRouter
# DEPLOY_DEPOSITOR=0x...  # deposits to LongevaPool & BackstopVault
